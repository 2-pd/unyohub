#!/usr/bin/env python3
# coding: utf-8

import importlib
import sys
import os
import subprocess


UNYOHUB_COMMANDS_APP_NAME = "鉄道運用Hub コマンドラインツール"
UNYOHUB_COMMANDS_VERSION = "26.04-2"

UNYOHUB_DATA_DIR = "../data"
UNYOHUB_CONFIG_DIR = "../config"


def mes (log_text, is_error=False, is_heading=False):
    if is_error:
        print("\x1b[31m\x1b[1m【エラー】\x1b[22m" + str(log_text) + "\x1b[0m")
    elif is_heading:
        print("\n\x1b[94m_/_/_/_/\x1b[0m " + str(log_text) + " \x1b[94m_/_/_/_/\x1b[0m\n")
    else:
        print(str(log_text))


args = []
options = set()
arg_count = 0
for arg_index in range(1, len(sys.argv)):
    if sys.argv[arg_index].startswith("-"):
        options.add(sys.argv[arg_index])
    else:
        args.append(sys.argv[arg_index])
        arg_count += 1

if "-s" not in options:
    print(UNYOHUB_COMMANDS_APP_NAME + " \x1b[90mv" + UNYOHUB_COMMANDS_VERSION + "\x1b[0m")

    if "--help" in options or "-h" in options:
        help_funcs = importlib.import_module("modules.help_funcs")
        help_funcs.show_help(*args[:1])
        
        sys.exit()

os.chdir(os.path.dirname(os.path.abspath(__file__)))
data_dir = (os.path.abspath(UNYOHUB_DATA_DIR))

if arg_count >= 1:
    match args[0]:
        case "setup-libs":
            if arg_count == 1 or arg_count == 2:
                subprocess.run(["php", "modules/libs_setup.php", *args[1:]])
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "embed-icons":
            if arg_count == 2:
                embed_train_icon = importlib.import_module("modules.embed_train_icon")
                embed_train_icon.embed_train_icon(mes, data_dir + "/" + os.path.basename(args[1]))
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "conv-formations":
            if arg_count == 2:
                convert_formation_table = importlib.import_module("modules.convert_formation_table")
                convert_formation_table.convert_formation_table(mes, data_dir + "/" + os.path.basename(args[1]))
                
                print("\n生成された編成表データに問題がなければ \x1b[93munyohub clean-formation-db\x1b[0m \x1b[90m<路線系統識別名>\x1b[0m を実行することで不要なデータを削除できます")
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "copy-formation-info":
            copy_formation_info = importlib.import_module("modules.copy_formation_info")
            if arg_count == 4 or arg_count == 5:
                copy_formation_info.copy_formation_info(mes, data_dir + "/" + os.path.basename(args[1]), args[2], data_dir + "/" + os.path.basename(args[3]), *args[4:])
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "clean-formation-db":
            if arg_count == 2:
                clean_formation_db_table = importlib.import_module("modules.clean_formation_db_table")
                clean_formation_db_table.clean_formation_db_table(mes, data_dir + "/" + os.path.basename(args[1]))
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "update-operations":
            if arg_count == 4:
                write_operations_to_db = importlib.import_module("modules.write_operations_to_db")
                write_operations_to_db.write_operations_to_db(mes, data_dir + "/" + os.path.basename(args[1]), os.path.basename(args[2]), os.path.basename(args[3]), options=options)
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "user-info":
            if arg_count <= 2:
                subprocess.run(["php", "modules/user_info.php", *args[1:]])
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "create-user":
            if arg_count == 3 or arg_count == 4:
                subprocess.run(["php", "modules/create_user.php", *args[1:]])
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "modify-user-info":
            subprocess.run(["php", "modules/modify_user_info.php", *sys.argv[2:]])
        case "role-info":
            if arg_count == 1 or arg_count == 2:
                subprocess.run(["php", "modules/role_info.php", *args[1:]])
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "create-role":
            if arg_count == 3:
                subprocess.run(["php", "modules/create_role.php", args[1], args[2]])
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "delete-role":
            if arg_count == 2:
                subprocess.run(["php", "modules/delete_role.php", args[1]])
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "add-permission":
            if arg_count == 4 or arg_count == 3:
                subprocess.run(["php", "modules/add_permission.php", *args[1:]])
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "remove-permission":
            if arg_count == 4 or arg_count == 3:
                subprocess.run(["php", "modules/remove_permission.php", *args[1:]])
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "assign-role":
            if arg_count == 3:
                subprocess.run(["php", "modules/assign_role.php", args[1], args[2]])
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "remove-role":
            if arg_count == 3:
                subprocess.run(["php", "modules/remove_role.php", args[1], args[2]])
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "init-db":
            if arg_count == 2:
                initialize_db = importlib.import_module("modules.initialize_db")
                initialize_db.initialize_db(mes, data_dir + "/" + os.path.basename(args[1]))
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "init-common-dbs":
            initialize_common_dbs = importlib.import_module("modules.initialize_common_dbs")
            initialize_common_dbs.initialize_common_dbs(mes, os.path.dirname(data_dir) + "/common_dbs")
        case "cache-transitions":
            if arg_count <= 3:
                cache_transition_data = importlib.import_module("modules.cache_transition_data")
                cache_transition_data.cache_transition_data(mes, data_dir, os.path.abspath(UNYOHUB_CONFIG_DIR), *args[1:], options=options)
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "get-gtfs-realtime":
            if arg_count <= 2:
                get_gtfs_realtime = importlib.import_module("modules.get_gtfs_realtime")
                get_gtfs_realtime.get_gtfs_realtime(mes, *args[1:], options=options)
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "update-trip-ids":
            if arg_count == 4:
                update_trip_ids = importlib.import_module("modules.update_trip_ids")
                update_trip_ids.update_trip_ids(mes, data_dir + "/" + os.path.basename(args[1]), os.path.basename(args[2]), os.path.basename(args[3]), options=options)
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case "generate-operation-table":
            if arg_count == 3:
                generate_operation_table = importlib.import_module("modules.generate_operation_table")
                generate_operation_table.generate_operation_table(mes, data_dir + "/" + os.path.basename(args[1]), args[2])
            else:
                print("\x1b[31m引数の数が異常です\x1b[0m")
        case _:
            print("\x1b[31mサブコマンド \x1b[1m" + args[0] + "\x1b[22m は存在しません\x1b[0m")
            print("\nヘルプを表示するには \x1b[93munyohub --help\x1b[0m を実行してください")
else:
    print("\nヘルプを表示するには \x1b[93munyohub --help\x1b[0m を実行してください")
